{
  "name": "dormouse-standalone",
  "private": true,
  "version": "0.1.0",
  "license": "FSL-1.1-MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm stage && tsc -b && vite build",
    "stage": "pnpm stage:dor-cli && pnpm stage:sidecar-proxy",
    "stage:dor-cli": "pnpm --filter dor build && node scripts/stage-dor-cli.mjs",
    "stage:sidecar-proxy": "node scripts/build-sidecar-proxy.mjs",
    "tauri": "pnpm stage && tauri",
    "test": "vitest run"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "0.12.0-beta.219",
    "@xterm/addon-unicode-graphemes": "0.5.0-beta.219",
    "@xterm/xterm": "6.1.0-beta.219",
    "dockview-react": "^5.1.0",
    "dormouse-lib": "workspace:*",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.6"
  }
}
